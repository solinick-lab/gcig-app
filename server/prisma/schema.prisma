generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  President
  CIO
  SeniorPortfolioManager
  PortfolioManager
  SeniorAnalyst
  JuniorAnalyst
}

enum AttendanceStatus {
  Present
  Absent
  Excused
}

enum VoteAction {
  Buy
  Hold
  Sell
}

model User {
  id              Int              @id @default(autoincrement())
  name            String
  email           String           @unique
  passwordHash    String
  role            Role
  createdAt       DateTime         @default(now())
  attendance      Attendance[]
  createdSessions VotingSession[]  @relation("SessionCreator")
  ballots         Ballot[]
}

model Pitch {
  id              Int              @id @default(autoincrement())
  pitcherName     String
  ticker          String
  date            DateTime
  location        String?
  slideshowUrl    String?
  createdAt       DateTime         @default(now())
  votingSessions  VotingSession[]
}

model VotingSession {
  id         Int       @id @default(autoincrement())
  ticker     String
  title      String?
  pitchId    Int?
  pitch      Pitch?    @relation(fields: [pitchId], references: [id], onDelete: SetNull)
  status     String    @default("open")
  deadline   DateTime
  createdAt  DateTime  @default(now())
  createdBy  Int
  creator    User      @relation("SessionCreator", fields: [createdBy], references: [id])
  closedAt   DateTime?
  ballots    Ballot[]

  @@index([createdAt])
}

model Ballot {
  id        Int            @id @default(autoincrement())
  sessionId Int
  session   VotingSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    VoteAction
  note      String?
  castAt    DateTime       @default(now())

  @@unique([sessionId, userId])
}

model Event {
  id              Int          @id @default(autoincrement())
  title           String
  date            DateTime
  location        String?
  description     String?
  durationMinutes Int          @default(60)
  recurring       Boolean      @default(false)
  attendance      Attendance[]
  createdAt       DateTime     @default(now())
}

model Holding {
  id        Int      @id @default(autoincrement())
  ticker    String
  shares    Float
  costBasis Float
  addedAt   DateTime @default(now())
}

model Report {
  id          Int      @id @default(autoincrement())
  title       String
  author      String
  ticker      String?
  date        DateTime
  description String?
  fileUrl     String
  createdAt   DateTime @default(now())
}

model Attendance {
  id      Int              @id @default(autoincrement())
  userId  Int
  eventId Int
  status  AttendanceStatus
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model PendingVerification {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  code         String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model PendingInvite {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  role      Role
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PortfolioSnapshot {
  id         Int      @id @default(autoincrement())
  date       DateTime @unique
  totalValue Float
}
