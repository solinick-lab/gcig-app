generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  President
  CIO
  // Comms/PR officer. Not part of the investment hierarchy. Attendance
  // is NOT tracked for this role (see ATTENDANCE_EXEMPT_ROLES in
  // routes/attendance.js) — they don't attend regular club meetings
  // in a counted capacity.
  ChiefOfCommunication
  SeniorPortfolioManager
  PortfolioManager
  SeniorAnalyst
  Analyst
  JuniorAnalyst
  AdvisoryBoardMember
  FacultyAdvisory
}

enum AttendanceStatus {
  Present
  Absent
  Excused
}

enum VoteAction {
  Buy
  Hold
  Sell
}

enum PitchRequestStatus {
  Pending
  Approved
  Declined
}

enum LunchPeriod {
  First
  Second
  Both
}

model User {
  id                Int              @id @default(autoincrement())
  name              String
  email             String           @unique
  // Nullable so Google-only signups don't need a local password. They can
  // set one later via the forgot-password flow if they want dual login.
  passwordHash      String?
  googleId          String?          @unique
  role              Role
  extraRoles        Role[]           @default([])
  tokenVersion      Int              @default(0)
  twoFactorSecret        String?
  twoFactorEnabled       Boolean          @default(false) // any method active
  twoFactorTotpEnabled   Boolean          @default(false)
  twoFactorEmailEnabled  Boolean          @default(false)
  twoFactorMethod        String?          // legacy — retained to backfill; unused
  failedLogins           Int              @default(0)
  lockedUntil            DateTime?
  createdAt              DateTime         @default(now())
  // Day-of-week lunch period schedule. JSON shape:
  //   { mon: "First"|"Second"|"Both"|null, tue: ..., wed: ..., thu: ..., fri: ... }
  // Surfaced on the "Request a Pitch" form so the requester can see when
  // the President / target PM is free for a lunch meeting.
  lunchSchedule     Json?
  attendance        Attendance[]
  createdSessions   VotingSession[]  @relation("SessionCreator")
  ballots           Ballot[]
  industries        UserIndustry[]
  ledIndustries     Industry[]       @relation("IndustryLeader")
  pitchPresenters   PitchPresenter[]
  backupCodes       BackupCode[]
  twoFactorCodes    TwoFactorCode[]
  knownLogins       KnownLogin[]
  chatMessages      ChatMessage[]
  aiChatSessions    AiChatSession[]
  pitchRequests     PitchRequest[]   @relation("PitchRequestRequester")
  presidentDecisions PitchRequest[]  @relation("PitchRequestPresident")
  pmDecisions       PitchRequest[]   @relation("PitchRequestPM")
  rosterOverrides   EventRosterOverride[]
}

// Chat channels are addressed by a simple string:
//   "general"        — everyone has access
//   "industry:<id>"  — members of that industry only
model ChatMessage {
  id        Int      @id @default(autoincrement())
  channel   String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([channel, createdAt])
}

// Fingerprints of IPs a user has successfully signed in from. Used to warn
// them via email when a sign-in comes from a new location. IPs are hashed
// so the DB never stores raw IPs long-term.
model KnownLogin {
  id        Int      @id @default(autoincrement())
  userId    Int
  ipHash    String
  userAgent String?
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ipHash])
  @@index([userId])
}

model TwoFactorCode {
  id        Int      @id @default(autoincrement())
  userId    Int
  codeHash  String
  purpose   String   // 'setup' or 'login'
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BackupCode {
  id        Int       @id @default(autoincrement())
  userId    Int
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Industry {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  leaderId      Int?
  leader        User?          @relation("IndustryLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  members       UserIndustry[]
  pitches       Pitch[]
  pitchRequests PitchRequest[]
  createdAt     DateTime       @default(now())
}

// Member-initiated request to pitch a stock with the President. Approval
// gates on the President: PM may approve/decline informationally but the
// President's decision is what flips the request to Approved/Declined.
//
// `deckRef` mirrors the Pitch.slideshowUrl scheme: either
//   "onedrive:ITEM_ID" (uploaded via /api/files/upload), or
//   a plain http(s) URL (e.g. a Google Drive / Slides link the user pasted).
// Submission requires a deck attached — empty deckRef is rejected.
model PitchRequest {
  id                    Int                @id @default(autoincrement())
  requesterId           Int
  requester             User               @relation("PitchRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  ticker                String
  companyName           String?
  thesis                String?
  industryId            Int?
  industry              Industry?          @relation(fields: [industryId], references: [id], onDelete: SetNull)
  // Snapshot of the PM at submission time so we don't re-resolve on
  // approval/decline (industry leaders can change). Nullable because not
  // every industry has a leader assigned.
  pmId                  Int?
  pm                    User?              @relation("PitchRequestPM", fields: [pmId], references: [id], onDelete: SetNull)
  // Proposed meeting date + lunch period so the President / PM can see
  // exactly when the requester wants to meet.
  proposedDate          DateTime?
  proposedLunch         LunchPeriod?
  // "HH:MM" 24h string. Validated server-side against the lunch-block
  // schedule so we never persist an out-of-range time.
  proposedStartTime     String?
  // LIBRARY / LOWER_COMMONS / ATHLETIC_COMMONS — validated server-side
  // against an allowlist (kept as a string so adding rooms is a code
  // change, not a migration).
  room                  String?
  notes                 String?
  deckRef               String             // "onedrive:..." or http(s) URL
  status                PitchRequestStatus @default(Pending)
  presidentId           Int?
  president             User?              @relation("PitchRequestPresident", fields: [presidentId], references: [id], onDelete: SetNull)
  presidentDecidedAt    DateTime?
  presidentDeclineReason String?
  pmDecidedAt           DateTime?
  pmApproved            Boolean?
  pmDeclineReason       String?
  // Flags so the requester sees an in-app notification once when the
  // status changes — same pattern as PitchPresenter.seenAt.
  requesterSeenAt       DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([status, createdAt])
  @@index([requesterId])
}

model UserIndustry {
  userId     Int
  industryId Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  industry   Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@id([userId, industryId])
}

model PitchPresenter {
  pitchId    Int
  userId     Int
  assignedAt DateTime @default(now())
  seenAt     DateTime?
  pitch      Pitch    @relation(fields: [pitchId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([pitchId, userId])
}

model Pitch {
  id              Int              @id @default(autoincrement())
  pitcherName     String
  ticker          String
  date            DateTime
  location        String?
  slideshowUrl    String?
  industryId      Int?
  industry        Industry?        @relation(fields: [industryId], references: [id], onDelete: SetNull)
  // What the club decided after the pitch: "Buy" = we bought, "NoBuy" = we
  // voted no, null = not voted / still pending.
  votedOutcome    String?
  createdAt       DateTime         @default(now())
  votingSessions  VotingSession[]
  presenters      PitchPresenter[]
}

model VotingSession {
  id         Int       @id @default(autoincrement())
  ticker     String
  title      String?
  pitchId    Int?
  pitch      Pitch?    @relation(fields: [pitchId], references: [id], onDelete: SetNull)
  status     String    @default("open")
  deadline   DateTime
  createdAt  DateTime  @default(now())
  createdBy  Int
  creator    User      @relation("SessionCreator", fields: [createdBy], references: [id])
  closedAt   DateTime?
  // LLM-generated 2-3 sentence recap of the closed session: tally, who
  // supported, proposed allocation range, main concerns from notes.
  // Lazily filled the first time someone views the session after it closes.
  synthesis  String?
  ballots    Ballot[]

  @@index([createdAt])
}

model Ballot {
  id               Int            @id @default(autoincrement())
  sessionId        Int
  session          VotingSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId           Int
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  action           VoteAction
  // Required when action = Buy. Dollar amount the voter thinks the club
  // should allocate, constrained to $1,500–$10,000 at the API layer. Null
  // for Hold/Sell.
  investmentAmount Float?
  note             String?
  castAt           DateTime       @default(now())

  @@unique([sessionId, userId])
}

model Event {
  id              Int          @id @default(autoincrement())
  title           String
  date            DateTime
  location        String?
  description     String?
  durationMinutes Int          @default(60)
  recurring       Boolean      @default(false)
  // Audience scope. 'all' = visible to every member (default);
  // 'advisory' = tagged as an Advisory Board event. Used by the
  // Calendar filter button. Extend with other audiences later if needed.
  audience        String       @default("all")
  // Optional deck attached to the event — same scheme as Pitch.slideshowUrl
  // and Report.fileUrl: either an `onedrive:ITEM_ID` ref or a plain http(s)
  // URL (Google Slides, etc.). All members see a "View slideshow" link
  // when present.
  slideshowUrl    String?
  attendance      Attendance[]
  rosterOverrides EventRosterOverride[]
  createdAt       DateTime     @default(now())
}

// Per-event roster overrides set by the super admin. Two cases:
//   included = false → user explicitly REMOVED from the event's roster.
//                      Shadows the role-based default audience query.
//   included = true  → user explicitly ADDED. Persists a manual addition
//                      from the super-admin "add member" picker even
//                      before any attendance record is written.
// Marking attendance on a user (POST /attendance) clears any "excluded"
// override — they're definitely on the roster if they have a status.
model EventRosterOverride {
  eventId  Int
  userId   Int
  included Boolean
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @default(now()) @updatedAt

  @@id([eventId, userId])
}

model Holding {
  id        Int      @id @default(autoincrement())
  ticker    String
  shares    Float
  costBasis Float
  addedAt   DateTime @default(now())
}

model Report {
  id          Int      @id @default(autoincrement())
  title       String
  author      String
  ticker      String?
  date        DateTime
  description String?
  fileUrl     String
  createdAt   DateTime @default(now())
}

model Attendance {
  id      Int              @id @default(autoincrement())
  userId  Int
  eventId Int
  status  AttendanceStatus
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model PendingVerification {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  code         String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model PendingInvite {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  role      Role
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  userName   String?
  action     String
  resource   String?
  resourceId Int?
  metadata   String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

model PortfolioSnapshot {
  id         Int      @id @default(autoincrement())
  date       DateTime @unique
  totalValue Float
  cashValue  Float?
}

// A single purchase lot for a ticker. We may buy the same stock at different
// times and prices; tracking each lot gives us an exact cost basis instead
// of relying on the sheet's rounded avg cost column.
model HoldingLot {
  id            Int      @id @default(autoincrement())
  ticker        String
  shares        Float
  pricePerShare Float
  buyDate       DateTime
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ticker])
}

// Free-text investment thesis for a ticker we hold. One row per ticker.
// Editable only by super-admin. Consumed by the holding detail modal and
// (eventually) by the thesis-vs-news drift check in the risk panel.
model HoldingThesis {
  id            Int      @id @default(autoincrement())
  ticker        String   @unique
  thesis        String
  updatedByName String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

// Persistent conversations with the in-house AI Assistant. The client
// never ships history back — every turn the server reads the full thread
// from these tables so a forged "assistant" message can't be used as
// precedent against the scope directive. Cascade from User so account
// deletion cleans up the whole chat history.
model AiChatSession {
  id        Int             @id @default(autoincrement())
  userId    Int
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Auto-derived from the first user message (truncated). Nullable until
  // the first turn completes.
  title     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  messages  AiChatMessage[]

  @@index([userId, updatedAt])
}

model AiChatMessage {
  id        Int           @id @default(autoincrement())
  sessionId Int
  session   AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String        // 'user' | 'assistant'
  content   String
  // Per-reply telemetry for abuse review / debugging. Null on user rows.
  model     String?       // which provider served the turn
  latencyMs Int?
  createdAt DateTime      @default(now())

  @@index([sessionId, createdAt])
}

// AI-generated summary for an uploaded file, keyed by fileRef
// (same scheme used in Report.fileUrl / Pitch.slideshowUrl, e.g.
// "onedrive:ABC123"). One row per file — regenerations overwrite.
// Summaries are slow to produce (10-30s on the local GPU) so we
// persist them and let the UI fetch cached results.
model FileSummary {
  id         Int      @id @default(autoincrement())
  fileRef    String   @unique
  filename   String?  // Captured at generation time for display
  summary    String
  model      String?  // Which provider generated it (for future invalidation)
  charCount  Int?     // Size of the extracted text fed into the model
  truncated  Boolean  @default(false) // True when the source doc exceeded our char cap
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// OAuth tokens for file-storage providers (currently: OneDrive via
// Microsoft Graph). One row per provider — we always rebind the same
// account instead of multi-tenant. Stores the current access token +
// refresh token; access tokens expire hourly, refresh token is the
// long-lived credential used to mint new ones. If this row is empty,
// uploads are unavailable until a super admin runs the OAuth flow.
model FileProviderToken {
  id           Int      @id @default(autoincrement())
  provider     String   @unique // 'onedrive'
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String?
  email        String?  // Which account the tokens are bound to — displayed in admin.
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

// Monthly CPI forecast produced by the external Python forecaster running
// on the club's local server. The forecaster POSTs to /api/cpi/ingest with
// an HMAC signature; we upsert one row per `asOfMonth` (the latest CPI
// month used as input). Old runs are kept for the historical "what we
// predicted vs. what happened" backtest panel — never overwritten.
//
// `payload` stores the full JSON shape: forecasts[], backtest stats,
// per-model contributions, ensemble weights. The client reads from this
// JSON directly so the schema stays additive: the forecaster can grow
// new fields without a Prisma migration.
model CpiForecast {
  id        Int      @id @default(autoincrement())
  runAt     DateTime
  // "YYYY-MM" of the most recently RELEASED CPI month used as input.
  // Unique so the forecaster can re-POST a corrected run for the same
  // input month and we'll upsert rather than duplicate.
  asOfMonth String   @unique
  payload   Json
  createdAt DateTime @default(now())

  @@index([runAt])
}

// One row per (date, signalName). Mirrors DuckDB's signals_daily on
// the Windows server, with the latest publish winning on conflict.
// History feeds the sparklines on the /tankers panel.
model SeaSignal {
  date       DateTime @db.Date
  signalName String
  value      Float?
  updatedAt  DateTime @updatedAt

  @@id([date, signalName])
  @@index([signalName, date])
}

// Singleton row keyed on a fixed id. publish-snapshot upserts the
// rolling-latest payload here every two minutes. Storing the whole
// shape as Json keeps the schema flexible: we can add fields without
// migrations as the map UI evolves.
model SeaSnapshot {
  id          Int      @id @default(1)
  snapshotAt  DateTime
  vesselCount Int
  payload     Json
  updatedAt   DateTime @updatedAt
}

// LLM-generated priority tag for a news article, keyed by URL. Lets us skip
// re-ranking articles we've already classified — articles don't change after
// publish, so the classification is stable. One row per unique URL. `model`
// records which local model generated the tag; useful for invalidation later
// (e.g. clear rows where model = '3b' after upgrading to 14b).
model ArticleRanking {
  id        Int      @id @default(autoincrement())
  url       String   @unique
  // Legacy tier tag ('high' | 'medium' | 'low'). Nullable for backwards
  // compat with rows written before the score column existed.
  priority  String?
  // Current-gen ranking: 0.0–10.0 with one decimal. Higher = more material.
  score     Float?
  reason    String?
  // AI-generated summary of the article body, filled lazily the first time
  // anyone opens the reader for this URL.
  summary   String?
  // Ticker this article was first fetched under. Set on insert, never
  // overwritten on update. Used to exclude broad-market ETF news (VOO,
  // QQQ, etc.) from club-wide summaries like Week in Review.
  ticker    String?
  model     String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([ticker])
}
