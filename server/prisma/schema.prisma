generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  President
  CIO
  SeniorPortfolioManager
  PortfolioManager
  SeniorAnalyst
  Analyst
  JuniorAnalyst
  AdvisoryBoardMember
  FacultyAdvisory
}

enum AttendanceStatus {
  Present
  Absent
  Excused
}

enum VoteAction {
  Buy
  Hold
  Sell
}

model User {
  id                Int              @id @default(autoincrement())
  name              String
  email             String           @unique
  passwordHash      String
  role              Role
  extraRoles        Role[]           @default([])
  tokenVersion      Int              @default(0)
  twoFactorSecret        String?
  twoFactorEnabled       Boolean          @default(false) // any method active
  twoFactorTotpEnabled   Boolean          @default(false)
  twoFactorEmailEnabled  Boolean          @default(false)
  twoFactorMethod        String?          // legacy — retained to backfill; unused
  failedLogins           Int              @default(0)
  lockedUntil            DateTime?
  createdAt              DateTime         @default(now())
  attendance        Attendance[]
  createdSessions   VotingSession[]  @relation("SessionCreator")
  ballots           Ballot[]
  industries        UserIndustry[]
  ledIndustries     Industry[]       @relation("IndustryLeader")
  pitchPresenters   PitchPresenter[]
  backupCodes       BackupCode[]
  twoFactorCodes    TwoFactorCode[]
  knownLogins       KnownLogin[]
  chatMessages      ChatMessage[]
}

// Chat channels are addressed by a simple string:
//   "general"        — everyone has access
//   "industry:<id>"  — members of that industry only
model ChatMessage {
  id        Int      @id @default(autoincrement())
  channel   String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([channel, createdAt])
}

// Fingerprints of IPs a user has successfully signed in from. Used to warn
// them via email when a sign-in comes from a new location. IPs are hashed
// so the DB never stores raw IPs long-term.
model KnownLogin {
  id        Int      @id @default(autoincrement())
  userId    Int
  ipHash    String
  userAgent String?
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ipHash])
  @@index([userId])
}

model TwoFactorCode {
  id        Int      @id @default(autoincrement())
  userId    Int
  codeHash  String
  purpose   String   // 'setup' or 'login'
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BackupCode {
  id        Int       @id @default(autoincrement())
  userId    Int
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Industry {
  id        Int            @id @default(autoincrement())
  name      String         @unique
  leaderId  Int?
  leader    User?          @relation("IndustryLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  members   UserIndustry[]
  pitches   Pitch[]
  createdAt DateTime       @default(now())
}

model UserIndustry {
  userId     Int
  industryId Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  industry   Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@id([userId, industryId])
}

model PitchPresenter {
  pitchId    Int
  userId     Int
  assignedAt DateTime @default(now())
  seenAt     DateTime?
  pitch      Pitch    @relation(fields: [pitchId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([pitchId, userId])
}

model Pitch {
  id              Int              @id @default(autoincrement())
  pitcherName     String
  ticker          String
  date            DateTime
  location        String?
  slideshowUrl    String?
  industryId      Int?
  industry        Industry?        @relation(fields: [industryId], references: [id], onDelete: SetNull)
  // What the club decided after the pitch: "Buy" = we bought, "NoBuy" = we
  // voted no, null = not voted / still pending.
  votedOutcome    String?
  createdAt       DateTime         @default(now())
  votingSessions  VotingSession[]
  presenters      PitchPresenter[]
}

model VotingSession {
  id         Int       @id @default(autoincrement())
  ticker     String
  title      String?
  pitchId    Int?
  pitch      Pitch?    @relation(fields: [pitchId], references: [id], onDelete: SetNull)
  status     String    @default("open")
  deadline   DateTime
  createdAt  DateTime  @default(now())
  createdBy  Int
  creator    User      @relation("SessionCreator", fields: [createdBy], references: [id])
  closedAt   DateTime?
  // LLM-generated 2-3 sentence recap of the closed session: tally, who
  // supported, proposed allocation range, main concerns from notes.
  // Lazily filled the first time someone views the session after it closes.
  synthesis  String?
  ballots    Ballot[]

  @@index([createdAt])
}

model Ballot {
  id               Int            @id @default(autoincrement())
  sessionId        Int
  session          VotingSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId           Int
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  action           VoteAction
  // Required when action = Buy. Dollar amount the voter thinks the club
  // should allocate, constrained to $1,500–$10,000 at the API layer. Null
  // for Hold/Sell.
  investmentAmount Float?
  note             String?
  castAt           DateTime       @default(now())

  @@unique([sessionId, userId])
}

model Event {
  id              Int          @id @default(autoincrement())
  title           String
  date            DateTime
  location        String?
  description     String?
  durationMinutes Int          @default(60)
  recurring       Boolean      @default(false)
  attendance      Attendance[]
  createdAt       DateTime     @default(now())
}

model Holding {
  id        Int      @id @default(autoincrement())
  ticker    String
  shares    Float
  costBasis Float
  addedAt   DateTime @default(now())
}

model Report {
  id          Int      @id @default(autoincrement())
  title       String
  author      String
  ticker      String?
  date        DateTime
  description String?
  fileUrl     String
  createdAt   DateTime @default(now())
}

model Attendance {
  id      Int              @id @default(autoincrement())
  userId  Int
  eventId Int
  status  AttendanceStatus
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model PendingVerification {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  code         String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model PendingInvite {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  role      Role
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  userName   String?
  action     String
  resource   String?
  resourceId Int?
  metadata   String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

model PortfolioSnapshot {
  id         Int      @id @default(autoincrement())
  date       DateTime @unique
  totalValue Float
  cashValue  Float?
}

// A single purchase lot for a ticker. We may buy the same stock at different
// times and prices; tracking each lot gives us an exact cost basis instead
// of relying on the sheet's rounded avg cost column.
model HoldingLot {
  id            Int      @id @default(autoincrement())
  ticker        String
  shares        Float
  pricePerShare Float
  buyDate       DateTime
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ticker])
}

// LLM-generated priority tag for a news article, keyed by URL. Lets us skip
// re-ranking articles we've already classified — articles don't change after
// publish, so the classification is stable. One row per unique URL. `model`
// records which local model generated the tag; useful for invalidation later
// (e.g. clear rows where model = '3b' after upgrading to 14b).
model ArticleRanking {
  id        Int      @id @default(autoincrement())
  url       String   @unique
  // Legacy tier tag ('high' | 'medium' | 'low'). Nullable for backwards
  // compat with rows written before the score column existed.
  priority  String?
  // Current-gen ranking: 0.0–10.0 with one decimal. Higher = more material.
  score     Float?
  reason    String?
  // AI-generated summary of the article body, filled lazily the first time
  // anyone opens the reader for this URL.
  summary   String?
  model     String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
