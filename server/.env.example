DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gcig?schema=public"
JWT_SECRET="change-this-to-a-long-random-string"
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"

# Google Sheet used as the live portfolio source of truth.
# The sheet must be shared as "Anyone with the link can view".
GCIG_SHEET_ID="10b43Ry4YBfY_Uk_8nIlJLjmfNgzzjAm6BjN7UewSdRQ"
GCIG_SHEET_GID="0"

# Cloudflare R2 storage for file uploads (pitches / reports).
# If any of these are unset, uploads fall back to the local server/uploads/ directory.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Gmail SMTP for sending verification codes and invite emails.
# Enable 2FA on the Gmail account, then create an App Password at
# https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Shared secret between the server and the GitHub Actions daily-snapshot cron.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
