# Development: leave empty — Vite proxies /api to http://localhost:4000
# Production: set to the full URL of the deployed API, e.g.
#   VITE_API_BASE_URL=https://gcig-api.onrender.com
VITE_API_BASE_URL=

# Google OAuth client ID — same value as GOOGLE_CLIENT_ID on the server.
# Leave blank to hide the "Sign in with Google" button.
VITE_GOOGLE_CLIENT_ID=
